{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "",
  "installCommand": "",
  "framework": null,
  "outputDirectory": "snapshot/2026-06-05",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/_cdn/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_media/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
