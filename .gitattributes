# Track large snapshot binaries with Git LFS (recommended before first push).
# Setup:
#   git lfs install
#   git lfs track "snapshot/**/*.jpg"
#   git lfs track "snapshot/**/*.jpeg"
#   git lfs track "snapshot/**/*.png"
#   git lfs track "snapshot/**/*.gif"
#   git lfs track "snapshot/**/*.webp"
#   git lfs track "snapshot/**/*.js"
#   git lfs track "snapshot/**/*.css"
#   git lfs track "snapshot/**/*.woff2"
#   git add .gitattributes

snapshot/**/*.jpg filter=lfs diff=lfs merge=lfs -text
snapshot/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
snapshot/**/*.png filter=lfs diff=lfs merge=lfs -text
snapshot/**/*.gif filter=lfs diff=lfs merge=lfs -text
snapshot/**/*.webp filter=lfs diff=lfs merge=lfs -text
snapshot/**/*.bin filter=lfs diff=lfs merge=lfs -text
snapshot/**/_cdn/** filter=lfs diff=lfs merge=lfs -text
snapshot/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
snapshot/**/*.ttf filter=lfs diff=lfs merge=lfs -text
snapshot/**/*.woff2 filter=lfs diff=lfs merge=lfs -text
